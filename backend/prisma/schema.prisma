generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  patient
  doctor
  admin
  government
}

enum UserStatus {
  active
  inactive
  pending
  suspended
}

enum Gender {
  male
  female
  other
}

enum AppointmentType {
  general
  follow_up
  emergency
  specialist
}

enum AppointmentStatus {
  pending
  confirmed
  arrived
  waiting
  completed
  cancelled
  late
  no_show
}

enum RecordStatus {
  normal
  elevated
  low
  critical
  pending
}

enum PrescriptionStatus {
  active
  completed
  cancelled
  expired
}

enum AllergenSeverity {
  mild
  moderate
  severe
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum NoteType {
  general
  follow_up
  diagnosis
  prescription
  referral
}

enum NotificationType {
  appointment
  medication
  lab_result
  message
  alert
  system
}

enum ScanResult {
  safe
  warning
  danger
}

enum AlertPriority {
  low
  medium
  high
  critical
}

enum AlertSeverity {
  info
  warning
  critical
}

enum HealthRating {
  excellent
  good
  moderate
  poor
}

model User {
  id                Int          @id @default(autoincrement())
  name              String       @db.VarChar(255)
  email             String       @unique @db.VarChar(255)
  password          String       @db.VarChar(255)
  role              Role         @default(patient)
  status            UserStatus   @default(active)
  nhsId             String?      @unique @map("nhs_id") @db.VarChar(50)
  phone             String?      @db.VarChar(20)
  dateOfBirth       DateTime?    @map("date_of_birth") @db.Date
  gender            Gender?
  address           String?
  bloodType         String?      @map("blood_type") @db.VarChar(5)
  allergiesSummary  String?      @map("allergies_summary")
  profileImage      String?      @map("profile_image") @db.VarChar(500)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  doctor            Doctor?
  patientAppts      Appointment[] @relation("PatientAppointments")
  doctorAppts       Appointment[] @relation("DoctorAppointments")
  healthMetrics     HealthMetric[]
  allergies         Allergy[]
  vaccinations      Vaccination[]
  patientPrescriptions Prescription[] @relation("PatientPrescriptions")
  doctorPrescriptions  Prescription[] @relation("DoctorPrescriptions")
  dietLogs          DietLog[]
  waterLogs         WaterLog[]
  sentMessages      Message[]    @relation("SentMessages")
  receivedMessages  Message[]    @relation("ReceivedMessages")
  notifications     Notification[]
  patientNotes      ClinicalNote[] @relation("PatientNotes")
  doctorNotes       ClinicalNote[] @relation("DoctorNotes")
  familyHistory     FamilyHistory[]
  documents         Document[]
  ingredientScans   IngredientScan[]
  patientAlerts     HealthAlert[] @relation("PatientAlerts")
  doctorAlerts      HealthAlert[] @relation("DoctorAlerts")
  patientRecords    MedicalRecord[] @relation("PatientRecords")
  doctorRecords     MedicalRecord[] @relation("DoctorRecords")
  patientPrescriptionOrders PrescriptionOrder[] @relation("PatientPrescriptionOrders")
  doctorPrescriptionOrders  PrescriptionOrder[] @relation("DoctorPrescriptionOrders")
  questionnaire     PatientQuestionnaire?
  questionnaireAnswers QuestionnaireAnswer[]
  foodIntolerances  FoodIntolerance[]
  dietPreferences   DietPreference[]
  ingredientDislikes IngredientDislike[]
  wearableTokens    WearableToken[]
  googleFitDriveImports GoogleFitDriveImport[]

  @@map("users")
}

model Doctor {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  specialization String? @db.VarChar(100)
  hospital     String?  @db.VarChar(255)
  hcpcNumber   String?  @map("hcpc_number") @db.VarChar(50)
  hcpcVerified Boolean  @default(false) @map("hcpc_verified")
  rating       Decimal  @default(0.0) @db.Decimal(3, 2)
  bio          String?
  availability String?
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule     DoctorSchedule[]

  @@map("doctors")
}

model Appointment {
  id              Int               @id @default(autoincrement())
  patientId       Int               @map("patient_id")
  doctorId        Int               @map("doctor_id")
  appointmentDate DateTime          @map("appointment_date") @db.Date
  appointmentTime DateTime          @map("appointment_time") @db.Time
  reason          String?
  type            AppointmentType   @default(general)
  status          AppointmentStatus @default(pending)
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")

  patient         User @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model MedicalRecord {
  id        Int          @id @default(autoincrement())
  patientId Int          @map("patient_id")
  doctorId  Int?         @map("doctor_id")
  testType  String       @map("test_type") @db.VarChar(100)
  result    String?
  status    RecordStatus @default(pending)
  notes     String?
  testDate  DateTime?    @map("test_date") @db.Date
  filePath  String?      @map("file_path") @db.VarChar(500)
  createdAt DateTime     @default(now()) @map("created_at")

  patient   User @relation("PatientRecords", fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User? @relation("DoctorRecords", fields: [doctorId], references: [id])

  @@map("medical_records")
}

model Prescription {
  id             Int                @id @default(autoincrement())
  patientId      Int                @map("patient_id")
  doctorId       Int?               @map("doctor_id")
  medicationName String             @map("medication_name") @db.VarChar(255)
  dosage         String?            @db.VarChar(100)
  frequency      String?            @db.VarChar(100)
  duration       String?            @db.VarChar(100)
  startDate      DateTime?          @map("start_date") @db.Date
  endDate        DateTime?          @map("end_date") @db.Date
  instructions   String?
  status         PrescriptionStatus @default(active)
  refillRequested Boolean           @default(false) @map("refill_requested")
  filePath       String?            @map("file_path") @db.VarChar(500)
  createdAt      DateTime           @default(now()) @map("created_at")

  patient        User @relation("PatientPrescriptions", fields: [patientId], references: [id], onDelete: Cascade)
  doctor         User? @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  orders         PrescriptionOrder[]

  @@map("prescriptions")
}

enum PrescriptionOrderStatus {
  pending
  approved
  preparing
  dispatched
  delivered
  rejected
  cancelled
}

enum DeliveryMethod {
  collection
  delivery
}

model PrescriptionOrder {
  id              Int                     @id @default(autoincrement())
  prescriptionId  Int                     @map("prescription_id")
  patientId       Int                     @map("patient_id")
  doctorId        Int                     @map("doctor_id")
  status          PrescriptionOrderStatus @default(pending)
  deliveryMethod  DeliveryMethod          @default(collection) @map("delivery_method")
  deliveryAddress String?                 @map("delivery_address")
  pharmacyName    String?                 @map("pharmacy_name") @db.VarChar(150)
  patientNotes    String?                 @map("patient_notes")
  doctorNotes     String?                 @map("doctor_notes")
  estimatedReady  DateTime?               @map("estimated_ready")
  paymentIntentId String?                 @map("payment_intent_id") @db.VarChar(255)
  orderedAt       DateTime                @default(now()) @map("ordered_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  prescription    Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  patient         User @relation("PatientPrescriptionOrders", fields: [patientId], references: [id], onDelete: Cascade)
  doctor          User @relation("DoctorPrescriptionOrders", fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("prescription_orders")
}

model Allergy {
  id          Int              @id @default(autoincrement())
  userId      Int              @map("user_id")
  allergen    String           @db.VarChar(255)
  reaction    String?          @db.VarChar(255)
  severity    AllergenSeverity @default(moderate)
  notes       String?
  allergyType String           @default("food") @map("allergy_type") @db.VarChar(50)
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("allergies")
}

model FoodIntolerance {
  id          Int              @id @default(autoincrement())
  userId      Int              @map("user_id")
  intolerance String           @db.VarChar(255)
  severity    AllergenSeverity @default(moderate)
  isActive    Boolean          @default(true) @map("is_active")
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("food_intolerances")
}

model DietPreference {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  preference String   @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diet_preferences")
}

model IngredientDislike {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  ingredient String   @db.VarChar(255)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ingredient_dislikes")
}

model Vaccination {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  vaccineName     String    @map("vaccine_name") @db.VarChar(255)
  doseNumber      Int       @default(1) @map("dose_number")
  dateAdministered DateTime? @map("date_administered") @db.Date
  nextDueDate     DateTime? @map("next_due_date") @db.Date
  batchNumber     String?   @map("batch_number") @db.VarChar(100)
  administeredBy  String?   @map("administered_by") @db.VarChar(255)
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vaccinations")
}

model HealthMetric {
  id               Int      @id @default(autoincrement())
  userId           Int      @map("user_id")
  systolic         Int?
  diastolic        Int?
  heartRate        Int?     @map("heart_rate")
  oxygenSaturation Decimal? @map("oxygen_saturation") @db.Decimal(5, 2)
  temperature      Decimal? @db.Decimal(5, 2)
  steps            Int?
  sleepHours       Decimal? @map("sleep_hours") @db.Decimal(4, 2)
  weight           Decimal? @db.Decimal(6, 2)
  bmi              Decimal? @db.Decimal(5, 2)
  bloodGlucose     Decimal? @map("blood_glucose") @db.Decimal(6, 2)
  stressLevel      Int?     @map("stress_level")
  caloriesBurned   Int?     @map("calories_burned")
  distanceKm       Decimal? @map("distance_km") @db.Decimal(6, 2)
  source           String   @default("manual") @db.VarChar(20)
  recordedAt       DateTime @default(now()) @map("recorded_at")

  user             User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("health_metrics")
}

model WearableToken {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  provider     String    @default("google_fit") @db.VarChar(20)
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  lastSync     DateTime? @map("last_sync")
  connectedAt  DateTime  @default(now()) @map("connected_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("wearable_tokens")
}

model GoogleFitDriveImport {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  driveFileId   String    @map("drive_file_id") @db.VarChar(200)
  fileName      String    @map("file_name") @db.VarChar(255)
  modifiedTime  String?   @map("modified_time") @db.VarChar(50)
  importedRows  Int       @default(0) @map("imported_rows")
  latestDate    DateTime? @map("latest_date") @db.Date
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, driveFileId])
  @@map("google_fit_drive_imports")
}

model DietLog {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  foodName String   @map("food_name") @db.VarChar(255)
  mealType MealType @map("meal_type")
  calories Int?
  protein  Decimal? @db.Decimal(6, 2)
  carbs    Decimal? @db.Decimal(6, 2)
  fat      Decimal? @db.Decimal(6, 2)
  fiber    Decimal? @db.Decimal(6, 2)
  logDate  DateTime @default(now()) @map("log_date")

  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("diet_logs")
}

model WaterLog {
  id      Int      @id @default(autoincrement())
  userId  Int      @map("user_id")
  glasses Int      @default(0)
  ml      Int?
  logDate DateTime @default(now()) @map("log_date") @db.Date

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("water_logs")
}

model Message {
  id          Int      @id @default(autoincrement())
  senderId    Int      @map("sender_id")
  receiverId  Int      @map("receiver_id")
  content     String
  isRead      Boolean  @default(false) @map("is_read")
  isEmergency Boolean  @default(false) @map("is_emergency")
  createdAt   DateTime @default(now()) @map("created_at")

  sender      User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  type      NotificationType @default(system)
  title     String           @db.VarChar(255)
  message   String?
  isRead    Boolean          @default(false) @map("is_read")
  link      String?          @db.VarChar(500)
  createdAt DateTime         @default(now()) @map("created_at")

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model ClinicalNote {
  id        Int      @id @default(autoincrement())
  patientId Int      @map("patient_id")
  doctorId  Int      @map("doctor_id")
  noteType  NoteType @default(general) @map("note_type")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  patient   User @relation("PatientNotes", fields: [patientId], references: [id], onDelete: Cascade)
  doctor    User @relation("DoctorNotes", fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("clinical_notes")
}

model FamilyHistory {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  relation       String?  @db.VarChar(50)
  relationName   String?  @map("relation_name") @db.VarChar(255)
  conditionName  String   @map("condition_name") @db.VarChar(255)
  diagnosisYear  Int?     @map("diagnosis_year")
  yearDeceased   Int?     @map("year_deceased")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("family_history")
}

model PatientQuestionnaire {
  id          Int       @id @default(autoincrement())
  patientId   Int       @unique @map("patient_id")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  startedAt   DateTime  @default(now()) @map("started_at")

  patient     User @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("patient_questionnaire")
}

model QuestionnaireAnswer {
  id          Int      @id @default(autoincrement())
  patientId   Int      @map("patient_id")
  questionKey String   @map("question_key") @db.VarChar(100)
  answer      String?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  patient     User @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, questionKey])
  @@map("patient_questionnaire_answers")
}

model Document {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String?  @db.VarChar(255)
  description String?
  docType     String   @default("other") @map("doc_type") @db.VarChar(50)
  filePath    String?  @map("file_path") @db.VarChar(500)
  fileName    String?  @map("file_name") @db.VarChar(255)
  fileType    String?  @map("file_type") @db.VarChar(50)
  fileSize    Int?     @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model IngredientScan {
  id          Int        @id @default(autoincrement())
  userId      Int        @map("user_id")
  productName String?    @map("product_name") @db.VarChar(255)
  ingredients String?
  result      ScanResult @default(safe)
  alerts      String?
  aiSummary   String?    @map("ai_summary")
  tip         String?
  createdAt   DateTime   @default(now()) @map("created_at")

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ingredient_scans")
}

model AccessLog {
  id                Int      @id @default(autoincrement())
  userId            Int      @map("user_id")
  accessedPatientId Int?     @map("accessed_patient_id")
  action            String?  @db.VarChar(255)
  ipAddress         String?  @map("ip_address") @db.VarChar(45)
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("access_logs")
}

model HealthAlert {
  id         Int           @id @default(autoincrement())
  patientId  Int           @map("patient_id")
  doctorId   Int?          @map("doctor_id")
  alertType  String?       @map("alert_type") @db.VarChar(100)
  message    String?
  priority   AlertPriority @default(medium)
  isResolved Boolean       @default(false) @map("is_resolved")
  createdAt  DateTime      @default(now()) @map("created_at")

  patient    User @relation("PatientAlerts", fields: [patientId], references: [id], onDelete: Cascade)
  doctor     User? @relation("DoctorAlerts", fields: [doctorId], references: [id])

  @@map("health_alerts")
}

model PublicHealthAlert {
  id        Int           @id @default(autoincrement())
  title     String        @db.VarChar(255)
  message   String?
  severity  AlertSeverity @default(info)
  region    String?       @db.VarChar(100)
  issuedBy  Int?          @map("issued_by")
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("public_health_alerts")
}

model FoodDatabase {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(255)
  calories     Int?
  protein      Decimal?     @db.Decimal(6, 2)
  carbs        Decimal?     @db.Decimal(6, 2)
  fat          Decimal?     @db.Decimal(6, 2)
  fiber        Decimal?     @db.Decimal(6, 2)
  allergens    String?
  healthRating HealthRating @default(moderate) @map("health_rating")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("food_database")
}

model GeneticDisease {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(255)
  inheritanceType  String?  @map("inheritance_type") @db.VarChar(100)
  symptoms         String?
  foodTriggers     String?  @map("food_triggers")
  exerciseGuidance String?  @map("exercise_guidance")
  carePlan         String?  @map("care_plan")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("genetic_diseases")
}

model DoctorSchedule {
  id          Int      @id @default(autoincrement())
  doctorId    Int      @map("doctor_id")
  dayOfWeek   Int      @map("day_of_week") @db.SmallInt
  startTime   DateTime? @map("start_time") @db.Time
  endTime     DateTime? @map("end_time") @db.Time
  isAvailable Boolean  @default(true) @map("is_available")

  doctor      Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("doctor_schedule")
}
