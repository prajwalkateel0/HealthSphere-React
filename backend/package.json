{
  "name": "healthsphere-backend",
  "version": "1.0.0",
  "description": "HealthSphere API Server",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "npx prisma generate && npx prisma migrate deploy",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node seed.js",
    "db:import:php": "node scripts/import-php-dump.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.7.2",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  }
}
